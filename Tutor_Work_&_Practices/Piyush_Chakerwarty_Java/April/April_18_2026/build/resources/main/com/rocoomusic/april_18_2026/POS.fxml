<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<VBox alignment="TOP_CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rocoomusic.april_18_2026.POSController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text = "Andrew's Cafe POS" style ="-fx-font-size: 24px; -fx-font-weight: bold"/>
    <HBox spacing = "10" alignment = "CENTER">
        <Label text = "Customer Name: " />
        <TextField fx:id="customerNameField" promptText="Enter Name..." />
        <Button fx:id ="startOrderButton" text ="Start Order" />
    </HBox>
    <Label fx:id="orderStatusLabel" text="Waiting for new customer..." style="-fx-text-fill: gray; -fx-font-style: italic"/>

    <HBox spacing="50" alignment="CENTER">
        <VBox spacing="10" alignment="CENTER">
            <Label text="Menu" style ="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Button text="Add Espresso ($3.00" onAction="#handleAddEspresso"/>
            <Button text="Add Latte ($4.50)" onAction="#handleAddLatte"/>
        </VBox>

        <VBox spacing="10" alignment="TOP_LEFT">
            <Label text="Live Receipt" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <VBox fx:id="receiptBox" spacing="5"/>

            <Button text="Clear Order" onAction="#handleClearOrder" style="-fx-text-fill: red;"/>
        </VBox>
    </HBox>

</VBox>
